{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*/*?*" },
        { "url": "https://*:*/*?*" }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" },
        { "url": "mailto:*" }
      ]
    },
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default",
    "process:allow-restart"
  ]
}
