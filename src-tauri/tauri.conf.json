{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Agno Desktop",
  "version": "0.0.3",
  "identifier": "dev.local.agnodesktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "TAURI_DEV_PORT=5180 bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agno Desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null,
      "freezePrototype": false
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local desktop client for AGNO AgentOS",
    "longDescription": "Connect to one or more AGNO AgentOS instances and chat with streaming tool calls, reasoning blocks, and rich Markdown rendering.",
    "publisher": "Agno Desktop Project"
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/yxc023/agno-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExNzE1NjBDNEY4QTNBN0QKUldSOU9vcFBERlp4RWNaV3U4STI3MHJKaHdOUGNaVk5UMTJXaEFLeVdOSmkwM250ekhyL3Q3dVMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
